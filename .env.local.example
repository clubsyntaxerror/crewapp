# Google Sheets Configuration

# Your Google Sheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
EXPO_PUBLIC_GOOGLE_SHEET_ID=your_sheet_id_here

# Sheet name/tab (default: Events)
EXPO_PUBLIC_GOOGLE_SHEET_NAME=Events

# Service Account Credentials
# From your Google Cloud service account JSON key file
EXPO_PUBLIC_GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
EXPO_PUBLIC_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Supabase Configuration

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anon/public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Discord OAuth Configuration

# Discord OAuth Client ID (from Discord Developer Portal)
EXPO_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Server (Guild) ID where role checking will happen
EXPO_PUBLIC_DISCORD_GUILD_ID=your_discord_guild_id_here

# Discord OAuth Client Secret (PRIVATE - used in Supabase Edge Functions)
# This should NOT be exposed to the client app
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Discord Bot Token (PRIVATE - used in Supabase Edge Functions for role verification)
# This should NOT be exposed to the client app
DISCORD_BOT_TOKEN=your_discord_bot_token_here
